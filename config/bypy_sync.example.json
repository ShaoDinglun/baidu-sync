{
  "bypy": {
    "binary": "bypy",
    "config_dir": "/app/config/.bypy",
    "retry_times": 3,
    "retry_delay_seconds": 5,
    "retry_backoff": 2,
    "network_timeout": 300,
    "command_timeout": 0,
    "command_heartbeat_seconds": 15,
    "min_command_interval_seconds": 1.0,
    "processes": 1,
    "verify_download": false,
    "log_dir": "log/bypy_sync",
    "summary_file": "log/bypy_sync/last_run.json",
    "lock_file": "log/bypy_sync/bypy_full_sync.lock",
    "state_file": "log/bypy_sync/current_state.json"
  },
  "tasks": [
    {
      "task_id": "example-recent-task",
      "name": "示例任务：最近两个月同步",
      "enabled": true,
      "auto_run_enabled": true,
      "cron": "15 * * * *",
      "remote_root": "/示例目录",
      "local_root": "/app/data/example-recent-task",
      "sync_mode": "recent_months",
      "recent_value": 2,
      "overwrite_policy": "if_newer",
      "directory_filters": []
    },
    {
      "task_id": "example-manual-task",
      "name": "示例任务：手动指定子目录",
      "enabled": true,
      "auto_run_enabled": false,
      "cron": "",
      "remote_root": "/示例目录",
      "local_root": "/app/data/example-manual-task",
      "sync_mode": "manual",
      "recent_value": 0,
      "overwrite_policy": "if_newer",
      "directory_filters": [
        "分类A/2026-04",
        "分类B"
      ]
    },
    {
      "task_id": "example-full-task",
      "name": "示例任务：全量同步",
      "enabled": false,
      "auto_run_enabled": false,
      "cron": "0 2 * * *",
      "remote_root": "/另一份示例目录",
      "local_root": "/app/data/example-full-task",
      "sync_mode": "all",
      "recent_value": 0,
      "overwrite_policy": "if_newer",
      "directory_filters": []
    }
  ]
}